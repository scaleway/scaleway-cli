{{- if .PrivateNetworkID }}// Connect from a resource attached to private network {{ .PrivateNetworkID }}
{{ end -}}
const { Pool } = require("pg");

const pool = new Pool({
  host: "{{ .Host }}",
  port: {{ .Port }},
  user: "{{ .User }}",
  password: process.env.RDB_PASSWORD,
  database: "{{ .Database }}",
  ssl: { rejectUnauthorized: true },
});

module.exports = { pool };

